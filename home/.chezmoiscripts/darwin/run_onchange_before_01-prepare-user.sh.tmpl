#!{{ lookPath "bash" }}

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
#   @author         :   Chris Burnham
#   @file           :
#   @description    :   Prepare user
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# --------------------------------------------------------------------------------------------------
#   @description    :   Load script libraries
# --------------------------------------------------------------------------------------------------
{{ template "script-library" }}
# ==================================================================================================

# --------------------------------------------------------------------------------------------------
#   @description    :   Pre-flight
# --------------------------------------------------------------------------------------------------
LOG_LEVEL=5 # debug
# ==================================================================================================

# --------------------------------------------------------------------------------------------------
#   @description    :   Create directories
# --------------------------------------------------------------------------------------------------
if [[ ! -d "${HOME}/Code" ]]; then
  info "Creating directory: ${HOME}/Code/" -category "User" -icon "👤"
  mkdir -p "${HOME}/Code"
fi

{{ if .personal }}
if [[ ! -d "${HOME}/Code/github.com/"{{ .personal_git_user | quote }} ]]; then
  info "Creating directory: ${HOME}/Code/github.com/"{{ .personal_git_user | quote }} -category "User" -icon "👤"
  mkdir -p "${HOME}/Code/github.com/"{{ .personal_git_user | quote }}
fi
{{ end }}

if [[ ! -d "${HOME}/Projects" ]]; then
  info "Creating directory: ${HOME}/Projects/" -category "User" -icon "👤"
  mkdir -p "${HOME}/Projects"
fi

if [[ ! -d "${HOME}/tmp" ]]; then
  info "Creating directory: ${HOME}/tmp/" -category "User" -icon "👤"
  mkdir -p "${HOME}/tmp"
fi
# ==================================================================================================
